pipeline {
    agent any
    
    tools {
        nodejs 'NodeJS'
    }
    
    environment {
        DOCKER_IMAGE = 'your-dockerhub-username/todo-app:latest'
    }
    
    stages {
        // Stage 1: Checkout code from GitHub
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/YOUR_USERNAME/DSEVOPS.git',
                    credentialsId: 'github-token'
            }
        }
        
        // Stage 2: Install Backend Dependencies
        stage('Install Backend') {
            steps {
                dir('backend') {
                    sh 'npm install'
                }
            }
        }
        
        // Stage 3: Install Frontend Dependencies
        stage('Install Frontend') {
            steps {
                dir('frontend-todo') {
                    sh 'npm install'
                }
            }
        }
        
        // Stage 4: Build Frontend (React app)
        stage('Build Frontend') {
            steps {
                dir('frontend-todo') {
                    sh 'npm run build'
                }
            }
        }
        
        // Stage 5: Run Backend Tests
        stage('Test Backend') {
            steps {
                dir('backend') {
                    sh 'npm test'
                }
            }
            post {
                always {
                    junit 'backend/junit.xml'
                }
            }
        }
        
        // Stage 6: Run Frontend Tests
        stage('Test Frontend') {
            steps {
                dir('frontend-todo') {
                    sh 'CI=true npm test -- --watchAll=false --coverage'
                }
            }
            post {
                always {
                    junit 'frontend-todo/junit.xml'
                }
            }
        }
        
        // Stage 7: Build Docker Image
        stage('Build Docker Image') {
            steps {
                script {
                    sh "docker build -t ${DOCKER_IMAGE} ."
                }
            }
        }
        
        // Stage 8: Push to Docker Hub
        stage('Push to Docker Hub') {
            steps {
                script {
                    docker.withRegistry('', 'docker-hub-creds') {
                        sh "docker push ${DOCKER_IMAGE}"
                    }
                }
            }
        }
    }
    
    post {
        success {
            echo '✅ All stages passed! Image pushed to Docker Hub'
        }
        failure {
            echo '❌ Pipeline failed! Check the logs above'
        }
    }
}